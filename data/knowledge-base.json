            { "value": "alertas", "label": "Sistema de alertas" },
            { "value": "health_checks", "label": "Health checks" },
            { "value": "dashboard_monitoramento", "label": "Dashboard de métricas" },
            { "value": "rastreamento_erros", "label": "Rastreamento de erros (Sentry)" }
          ]
        },
        {
          "id": "ambientes",
          "type": "multi_choice",
          "question": "Ambientes configurados:",
          "options": [
            { "value": "dev", "label": "Desenvolvimento" },
            { "value": "staging", "label": "Staging/Homologação" },
            { "value": "producao", "label": "Produção" },
            { "value": "dr", "label": "Disaster Recovery" }
          ]
        },
        {
          "id": "backup_recuperacao",
          "type": "multi_choice",
          "question": "Estratégia de backup e recuperação:",
          "options": [
            { "value": "backup_automatico", "label": "Backups automáticos" },
            { "value": "backup_criptografado", "label": "Backups criptografados" },
            { "value": "teste_restore", "label": "Testes periódicos de restore" },
            { "value": "ponto_recuperacao", "label": "RPO definido" },
            { "value": "tempo_recuperacao", "label": "RTO definido" },
            { "value": "geograficamente_distribuido", "label": "Backup em múltiplas regiões" }
          ]
        }
      ],
      "checklists": {
        "checklist_aws": [
          "Configurar IAM com princípio do menor privilégio",
          "Habilitar MFA para acesso root",
          "Usar Secrets Manager para credenciais",
          "Configurar VPC com subnets privadas",
