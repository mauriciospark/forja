            { "value": "blue_green", "label": "Blue-Green Deployment" },
            { "value": "canary", "label": "Canary Releases" },
            { "value": "feature_flags", "label": "Feature Flags" }
          ]
        },
        {
          "id": "banco_dados",
          "type": "multi_choice",
          "question": "Banco de dados:",
          "options": [
            { "value": "postgres", "label": "PostgreSQL" },
            { "value": "mysql", "label": "MySQL/MariaDB" },
            { "value": "mongodb", "label": "MongoDB" },
            { "value": "redis", "label": "Redis (cache)" },
            { "value": "dynamodb", "label": "DynamoDB" },
            { "value": "firebase", "label": "Firebase" },
            { "value": "sqlite", "label": "SQLite (dev/teste)" },
            { "value": "elasticsearch", "label": "Elasticsearch" }
          ]
        },
        {
          "id": "monitoramento",
          "type": "multi_choice",
          "question": "Ferramentas de monitoramento:",
          "options": [
